# Local config & secrets — never commit
sd_template/3ds/3dssh/id_rsa
sd_template/3ds/3dssh/config.ini
*.key
id_rsa*
!sd_template/3ds/3dssh/id_rsa.example

# OpenRouter / dssh-whisper credentials — never check into git.  install
# scripts write them to ~/.config/dssh-whisper/ but a stray `git add .`
# from a HOME-ish working tree could otherwise sweep them up.
*api-key*
*api_key*
*openrouter*
.config/dssh-whisper/

